# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# Канал, куда бот постит (бот должен быть админом). Формат: @имяканала или -100xxxxxxxxxx
CHANNEL_ID=@moto_spain_afisha
# Группа, куда пересылать посты из канала (бот должен быть участником/админом).
# Оставь пустым, если группа привязана к каналу как "обсуждение" — тогда Telegram пересылает сам.
GROUP_ID=

# Anthropic (Claude) — ключ с console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# Модель: claude-sonnet-5 (быстро и дёшево, достаточно для перевода/постов) или claude-opus-4-8 (максимум качества)
CLAUDE_MODEL=claude-sonnet-5

# Расписание (по времени Испании, Europe/Madrid): час сбора и часы публикаций (по 1 посту)
COLLECT_HOUR=9
POST_HOURS=10,12,14,16,18,20
# Пересылок в группу в день (самые важные: законы, Аликанте/Валенсия/Мурсия, «сегодня/завтра»)
MAX_FORWARDS=2

# Рабочие часы канала (Испания): посты выходят только в этом окне
WORK_START=9
WORK_END=21
# Пауза между постами в одном запуске, секунд
POST_INTERVAL_SEC=45

# Мини-апп (календарь) и чат админа
# ADMIN_CHAT_ID — твой chat_id: напиши боту /start и посмотри в логах, либо спроси у @userinfobot
ADMIN_CHAT_ID=
WEBAPP_URL=https://aminoza-netizen.github.io/moto-events-bot/
# Прямая ссылка на мини-апп (кнопка под постами), регистрируется в BotFather через /newapp
APP_DIRECT_LINK=https://t.me/spainmotonews_bot/afisha
